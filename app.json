{
  "expo": {
    "name": "Campus Companion",
    "slug": "olmies-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.shaunramsay14.olmiesmobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8d9e9c78-a53b-4fbd-ac3f-c876a455b3e0"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8d9e9c78-a53b-4fbd-ac3f-c876a455b3e0"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Campus Companion to securely use your location to place your position dynamically on the physical campus map."
        }
      ],
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Campus Companion to access your microphone for instantaneous voice-to-text dictation on the map.",
          "speechRecognitionPermission": "Allow Campus Companion to use native Speech Recognition to instantly route your voice into text queries."
        }
      ]
    ]
  }
}
